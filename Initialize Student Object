class Student:
    def __init__(self, sid, name, dept, enrolled=True):
        self.student_id = sid
        self.name = name
        self.department = dept
        self.is_enrolled = enrolled

class StudentDatabase:
    student_list = []

    def add_student(cls, student_obj):
        cls.student_list.append(student_obj)

if __name__ == '__main__':
    s1 = Student(101, "Ayon Sen", "CSE")
    s2 = Student(102, "Nabila Islam", "EEE", enrolled=False)

    StudentDatabase.add_student(s1)
    StudentDatabase.add_student(s2)
    
    for s in StudentDatabase.student_list:
        print(f"ID: {s.student_id} | Name: {s.name} | Dept: {s.department} | Enrolled: {s.is_enrolled}")
